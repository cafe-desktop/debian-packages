.TH CDK-PIXBUF-PIXDATA "1" "November 2013" "cdk-pixbuf-pixdata" "User Commands"
.SH NAME
cdk-pixbuf-pixdata \- CDK Pixbuf library
.SH SYNOPSIS
.B cdk-pixbuf-pixdata
[\fIoptions\fR] [\fIinput-file\fR] [\fIoutput-file\fR]
.SH DESCRIPTION
.TP
\fB\-h\fR, \fB\-\-help\fR
show this help message
.TP
\fB\-v\fR, \fB\-\-version\fR
print version information
.TP
\fB\-\-g\-fatal\-warnings\fR
make warnings fatal (abort)
.PP
