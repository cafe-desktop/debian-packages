From: Sebastien Bacher <seb128@ubuntu.com>
Date: Wed, 27 Jul 2022 15:23:37 +0200
Subject: use the right cdk-pixbuf-query-loaders directory

Since the .install moves the binary to another location the .pc file
needs to be updated

Forwarded: not-needed
---
 cdk-pixbuf/meson.build | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/cdk-pixbuf/meson.build b/cdk-pixbuf/meson.build
index 8e3f171..eb1117c 100644
--- a/cdk-pixbuf/meson.build
+++ b/cdk-pixbuf/meson.build
@@ -445,7 +445,7 @@ pkgconfig.generate(
     'cdk_pixbuf_cache_file=${cdk_pixbuf_binarydir}/loaders.cache',
     'cdk_pixbuf_csource=${bindir}/cdk-pixbuf-csource',
     'cdk_pixbuf_pixdata=${bindir}/cdk-pixbuf-pixdata',
-    'cdk_pixbuf_query_loaders=${bindir}/cdk-pixbuf-query-loaders',
+    'cdk_pixbuf_query_loaders=${libdir}/@0@/cdk-pixbuf-query-loaders'.format(cdk_pixbuf_api_name),
   ],
   requires: 'gobject-2.0',
   subdirs: cdk_pixbuf_api_name,
